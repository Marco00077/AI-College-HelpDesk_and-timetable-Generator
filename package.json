{
  "name": "college-helpdesk-root",
  "version": "1.0.0",
  "description": "AI-Based College Helpdesk Chatbot with Timetable Generator",
  "scripts": {
    "install-all": "cd backend && npm install && cd ../frontend && npm install",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm start",
    "seed": "cd backend && node scripts/seedData.js",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "keywords": ["chatbot", "timetable", "college", "helpdesk"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
